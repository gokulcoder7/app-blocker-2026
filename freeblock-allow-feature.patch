+
+    // When an allowance's duration elapses, transition the list into a manual
+    // block so the rest of the system sees it as actively blocked and the
+    // user can clear it with the regular `unblock` command.
+    private static async Task ApplyExpiredAllowances()
+    {
+        bool changed = false;
+
+        foreach (var list in State.BlockLists)
+        {
+            if (!list.AllowanceExpired) continue;
+
+            list.AllowanceStart = null;
+            list.AllowanceDuration = null;
+            list.ManuallyBlocked = true;
+            changed = true;
+        }
+
+        if (changed) State.Save();
+    }
 }
