+    public DateTime? AllowanceStart { get; set; }
+    public TimeSpan? AllowanceDuration { get; set; }
+
+    public DateTime? AllowanceEndTime =>
+        AllowanceStart != null && AllowanceDuration != null
+            ? AllowanceStart.Value + AllowanceDuration.Value
+            : null;
+
+    public bool InAllowancePeriod =>
+        AllowanceEndTime != null && DateTime.Now < AllowanceEndTime;
+
+    public bool AllowanceExpired =>
+        AllowanceEndTime != null && DateTime.Now >= AllowanceEndTime;
+
+    public TimeSpan? AllowanceRemaining
+    {
+        get
+        {
+            var end = AllowanceEndTime;
+            if (end == null) return null;
+            var remaining = end.Value - DateTime.Now;
+            return remaining > TimeSpan.Zero ? remaining : null;
+        }
+    }
 }
