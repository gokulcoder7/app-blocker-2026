+async Task Allow(ListArgument listArgument, DurationArgument durationArgument)
+{
+    var list = listArgument.Value!;
+    var duration = durationArgument.Value!;
+    var allowanceStart = DateTime.Now;
+
+    if (list.InAllowancePeriod && list.AllowanceRemaining is { } remaining)
+        ConsoleUtils.Note($"Replacing current allowance ({remaining.Hours:D2}:{remaining.Minutes:D2}:{remaining.Seconds:D2} remaining) with a new one");
+
+    var prompt = $"This will allow you to use {list.Name} for {duration}. Once the time runs out, all browsers and blocked apps will close automatically. Okay to continue?";
+
+    if (!ConsoleUtils.PromptYesNo(prompt)) return;
+    await ConnectionManager.Connection!.InvokeAsync("AllowAsync", list, allowanceStart, duration);
+
+    Console.WriteLine($"Allowance started for {duration}: {list.Name}");
+}
