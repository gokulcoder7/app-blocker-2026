+public record DurationArgument(string Name) : Argument<TimeSpan>(Name)
+{
+    // Accepts e.g. "20m", "1h", "1h20m", "1h20m30s", "90s"
+    private static readonly Regex ShorthandRegex = new(
+        @"^(?:(\d+)h)?(?:(\d+)m)?(?:(\d+)s)?$",
+        RegexOptions.IgnoreCase
+    );
+
+    public override async Task<bool> Validate(string input)
+    {
+        var trimmed = input.Trim();
+
+        // Try TimeSpan / TimeOnly format first (HH:MM:SS, HH:MM, 1.02:00:00, etc.)
+        TimeSpan ts;
+        if (TimeSpan.TryParse(trimmed, out var parsedTs)) ts = parsedTs;
+        else if (TimeOnly.TryParse(trimmed, out var parsedTo)) ts = parsedTo.ToTimeSpan();
+        else goto Shorthand;
+
+        if (ts <= TimeSpan.Zero)
+        {
+            Console.WriteLine($"[{Name}] must be greater than zero");
+            return false;
+        }
+
+        Value = ts;
+        return true;
+
+    Shorthand:
+
+        // Try shorthand (20m, 1h, 1h20m, 90s)
+        var match = ShorthandRegex.Match(trimmed.ToLowerInvariant());
+        if (match.Success)
+        {
+            int hours = match.Groups[1].Success ? int.Parse(match.Groups[1].Value) : 0;
+            int minutes = match.Groups[2].Success ? int.Parse(match.Groups[2].Value) : 0;
+            int seconds = match.Groups[3].Success ? int.Parse(match.Groups[3].Value) : 0;
+
+            if (hours == 0 && minutes == 0 && seconds == 0)
+            {
+                Console.WriteLine($"[{Name}] must be greater than zero (e.g. 20m, 1h, 1h20m)");
+                return false;
+            }
+
+            Value = new TimeSpan(hours, minutes, seconds);
+            return true;
+        }
+
+        Console.WriteLine($"[{Name}] must be a valid duration: HH:MM:SS, HH:MM, or shorthand like 20m, 1h, 1h20m");
+        return false;
+    }
+}
